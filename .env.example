# ============================================================================
# Calculus Voice Agent — Environment Configuration
# ============================================================================

# --- Telephony ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
INBOUND_PHONE_NUMBER=+1XXXXXXXXXX

# --- STT (Modular Pipeline) ---
DEEPGRAM_API_KEY=

# --- TTS (Modular Pipeline) ---
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# --- LLM: GPT-4o (Fast Intent Classification + Simple Responses) ---
OPENAI_API_KEY=

# --- LLM: Claude (Compliance-Sensitive + Multi-Step Flows) ---
ANTHROPIC_API_KEY=

# --- LLM: Grok Voice (Speech-to-Speech for Informational Queries) ---
XAI_API_KEY=
GROK_VOICE_ENABLED=true

# --- Database ---
DATABASE_URL=postgresql://user:pass@localhost:5432/voice_agent
REDIS_URL=redis://localhost:6379

# --- Services ---
NYMBUS_API_URL=https://api.nymbus.com
LOANPRO_API_URL=https://api.loanpro.io
IFSE_TREASURY_URL=https://internal.ifse.calculus.com
CUSTODIAN_API_URL=https://internal.custody.calculus.com
EUREKA_API_URL=https://internal.eureka.calculus.com

# --- HubSpot (DMC + IFSE) ---
# Auth: Private App token or OAuth 2.0
# Scopes needed: crm.objects.contacts, crm.objects.deals, crm.objects.custom,
#   sales-email-read, crm.schemas.custom.read, tickets
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=

# --- GoHighLevel (Constitutional Tender + TILT + Eureka) ---
# Auth: OAuth 2.0 Agency or Sub-Account
# One location per model
GHL_API_KEY=
GHL_LOCATION_ID_CT=              # Constitutional Tender sub-account
GHL_LOCATION_ID_TILT=            # TILT Lending sub-account
GHL_LOCATION_ID_EUREKA=          # Eureka Settlement sub-account
# Pipeline IDs (configured in GHL dashboard)
GHL_PIPELINE_CT_SALES=           # CT metals sales pipeline
GHL_PIPELINE_TILT_BROKER=        # TILT broker/borrower pipeline
GHL_PIPELINE_TILT_SERVICING=     # TILT loan servicing pipeline
GHL_PIPELINE_EUREKA_SETTLEMENT=  # Eureka settlement pipeline
# Calendar IDs for appointment booking
GHL_CALENDAR_CT_SPECIALIST=      # CT metals specialist calendar
GHL_CALENDAR_TILT_LOAN_OFFICER=  # TILT loan officer calendar
GHL_CALENDAR_EUREKA_COORDINATOR= # Eureka settlement coordinator calendar
# Workflow IDs for automation triggers
GHL_WORKFLOW_CT_PRICE_ALERT=     # Trigger: gold drops 3%+
GHL_WORKFLOW_CT_POST_PURCHASE=   # Trigger: after metals purchase
GHL_WORKFLOW_TILT_SPEED_TO_LEAD= # Trigger: new Arbor/CoStar lead
GHL_WORKFLOW_TILT_NURTURE=       # Trigger: broker nurture sequence

# --- Compliance ---
SANCTIONS_API_URL=https://internal.compliance.calculus.com
FCC_REASSIGNED_NUMBERS_DB_KEY=
DNC_REGISTRY_API_KEY=
COMPLIANCE_ENFORCEMENT_MODE=strict

# --- Logging ---
LOG_LEVEL=info
AUDIT_LOG_ENABLED=true

# --- Feature Flags ---
ENABLE_GROK_SPEECH_TO_SPEECH=true
ENABLE_OUTBOUND_AI_CALLS=false
MAX_CALL_DURATION_MINUTES=30
